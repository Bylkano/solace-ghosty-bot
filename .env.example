# Copy this file to .env and fill in your values.
# Get your bot token from https://discord.com/developers/applications

DISCORD_TOKEN=your_bot_token_here
BOT_PREFIX=!
OWNER_ID=your_discord_user_id_here

# Optional: Guild ID for faster slash command syncing during development.
# Leave blank for global commands (can take up to 1 hour to propagate).
DEV_GUILD_ID=

# MongoDB connection string (required for Simon Says leaderboards).
# MongoDB Atlas example: mongodb+srv://<user>:<password>@cluster.xxxxx.mongodb.net/
MONGODB_URI=

# Groq API key (required for the Biki AI companion cog).
# Get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
