# Copy this file to .env and fill in your values.
# Get your bot token from https://discord.com/developers/applications

DISCORD_TOKEN=your_bot_token_here
BOT_PREFIX=!
OWNER_ID=your_discord_user_id_here

# Optional: Guild ID for faster slash command syncing during development.
# Leave blank for global commands (can take up to 1 hour to propagate).
DEV_GUILD_ID=

# MongoDB connection string (required).
# MongoDB Atlas example: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
# Local example:         mongodb://localhost:27017/
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/

# Optional: name of the MongoDB database (defaults to "ghosty_bot").
MONGODB_DB=ghosty_bot
