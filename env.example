# Copy this file to .env for local runs.
# On Render: set these in the service Environment tab (do not commit real secrets).

# Discord bot token (required) — either name works.
DISCORD_TOKEN=
# BOT_TOKEN=

BOT_PREFIX=!
OWNER_ID=

# Optional: guild ID for instant slash-command sync while developing.
# Leave blank for global commands (can take up to 1 hour to propagate).
DEV_GUILD_ID=

# PostgreSQL connection string (required).
# On Render: create a Postgres database, then paste its Internal Database URL
# into Environment variable DATABASE_URL on your worker service.
# Render Postgres needs SSL — the bot already uses sslmode=require.
DATABASE_URL=

# DeepInfra API token (optional unless you use AI features).
DEEPINFRA_TOKEN=
