# Copy this file to .env and fill in your values.
# Get your bot token from https://discord.com/developers/applications

DISCORD_TOKEN=your_bot_token_here
BOT_PREFIX=!
OWNER_ID=your_discord_user_id_here

# Optional: Guild ID for faster slash command syncing during development.
# Leave blank for global commands (can take up to 1 hour to propagate).
DEV_GUILD_ID=

# PostgreSQL connection string (required).
DATABASE_URL=

# DeepInfra API token (required for Biki AI).
# Get yours free at https://deepinfra.com/dash/api_keys
DEEPINFRA_TOKEN=AYkVy3iddIaPYcs1Uuv0hVNsii9BQB6L
